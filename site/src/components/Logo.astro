---
interface Props {
  size?: number;
  withWordmark?: boolean;
}
const { size = 24, withWordmark = false } = Astro.props;
---

<span class="logo" style={`--logo-size:${size}px`}>
  <svg viewBox="190 50 220 230" width={size} height={size} preserveAspectRatio="xMidYMid meet" aria-hidden="true">
    <g transform="translate(0,328) scale(0.1,-0.1)">
      <path fill="#6c63ff" d="M2490 2696 l-485 -122 0 -519 c0 -471 2 -528 19 -605 73 -333 278 -607 608 -812 134 -83 327 -172 373 -172 48 0 282 114 411 199 257 171 449 412 528 661 52 167 51 156 51 719 l0 529 -485 123 c-267 67 -496 122 -510 122 -14 0 -243 -55 -510 -123z"/>
      <path fill="#ffffff" d="M2935 2303 c-278 -41 -485 -277 -485 -553 0 -259 188 -492 439 -545 89 -19 137 -19 224 0 105 22 192 70 272 150 107 106 165 235 165 366 0 89 1 89 -242 89 -192 0 -206 1 -223 20 -31 34 -86 45 -127 26 -85 -40 -92 -154 -12 -207 48 -32 119 -19 147 28 6 10 47 13 169 13 l160 0 -7 -37 c-32 -172 -206 -321 -386 -331 -323 -19 -548 312 -413 607 115 254 444 331 654 155 57 -48 120 -29 120 36 0 46 -102 121 -219 159 -60 20 -183 32 -236 24z"/>
    </g>
  </svg>
  {withWordmark && <span class="wordmark">Gatehouse</span>}
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }
  .wordmark {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--text-primary);
  }
</style>
